# ===========================================
# BroadMind AI - WhatsApp Doubt Solver Bot
# ===========================================

# Twilio Credentials (https://console.twilio.com)
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# --- AI Providers (add at least one) ---

# Google Gemini (https://aistudio.google.com/apikey) — FREE tier
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI ChatGPT (https://platform.openai.com/api-keys)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic Claude (https://console.anthropic.com/settings/keys)
CLAUDE_API_KEY=your_claude_api_key_here

# Kimi / Moonshot AI (https://platform.moonshot.cn/console/api-keys)
KIMI_API_KEY=your_kimi_api_key_here
KIMI_BASE_URL=https://api.moonshot.cn/v1

# Default AI provider: gemini | chatgpt | claude | kimi
DEFAULT_AI_PROVIDER=gemini

# Server
PORT=3001
